# GW150914 Einstein Toolkit — 環境設定テンプレート
# このファイルを `.env` にコピーして環境に合わせて書き換える。
# `.env` は gitignore 対象。

# ============================================================
# シミュレーション出力先
# ============================================================
# HDF5 チェックポイントや診断出力を書き込むホスト側ディレクトリ。
# I/O が重いため **ローカル SSD** を強く推奨（NAS マウント下は避ける）。
# コンテナ内では /home/etuser/simulations にマウントされる。
SIM_OUTPUT_DIR=${HOME}/gw150914-output

# ============================================================
# Jupyter Lab ポート
# ============================================================
# ホスト側の公開ポート。他サービスと衝突する場合は変更する。
JUPYTER_PORT=8888

# ============================================================
# コンテナに割り当てる CPU とメモリ
# ============================================================
# 16 コア全部をシミュレーションに使う想定。他の作業と並行するなら減らす。
CONTAINER_CPUSET=0-15
CONTAINER_MEM_LIMIT=80g

# ============================================================
# 共有メモリサイズ
# ============================================================
# MPICH のプロセス間通信で使う。デフォルト(64MB)では不足するため
# 数 GB に引き上げる。
CONTAINER_SHM_SIZE=4gb

# ============================================================
# Docker ビルド時パラメータ
# ============================================================
# コンテナ内ユーザー (etuser) の UID/GID。ホストと一致させることで
# バインドマウント先のパーミッションを揃える。
# 通常はホストの `id -u` / `id -g` の値（Linux デスクトップなら 1000/1000）。
USER_UID=1000
USER_GID=1000

# Cactus ビルド時の make 並列度。コンパイル時メモリ消費量は概ね
# ファイル数 × 並列度 に比例する。OOM kill されたら下げる。
MAKE_PARALLEL=8

# ============================================================
# シミュレーション並列度 (Phase 3 以降で使用)
# ============================================================
# cactus_sim を走らせる際の MPI プロセス数と、1 MPI あたりの
# OpenMP スレッド数。SIM_MPI_PROCS × SIM_OMP_THREADS ≦ 物理コア数。
#
# 16 コア環境の推奨: np=8 × OMP=2 (Phase 3a qc0 smoke で検証済、
# 26 分で完走、~42 GB メモリ使用)。
# np=16 は OMP 未指定だと thread oversubscription で停止、
# OMP=1 でもメモリ上限 80 GB を超過するため非推奨。
SIM_MPI_PROCS=8
SIM_OMP_THREADS=2

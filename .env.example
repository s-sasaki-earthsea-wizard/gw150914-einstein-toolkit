# GW150914 Einstein Toolkit — 環境設定テンプレート
# このファイルを `.env` にコピーして環境に合わせて書き換える。
# `.env` は gitignore 対象。

# ============================================================
# シミュレーション出力先
# ============================================================
# HDF5チェックポイントや診断出力を書き込むホスト側ディレクトリ。
# I/O が重いため **ローカルSSD** を強く推奨（NASマウント下は避ける）。
# コンテナ内では /home/jovyan/simulations にマウントされる。
SIM_OUTPUT_DIR=${HOME}/gw150914-output

# ============================================================
# Jupyter Lab ポート
# ============================================================
# ホスト側の公開ポート。他サービスと衝突する場合は変更する。
JUPYTER_PORT=8888

# ============================================================
# コンテナに割り当てる CPU とメモリ
# ============================================================
# 16コア全部をシミュレーションに使う想定。他の作業と並行するなら減らす。
CONTAINER_CPUSET=0-15
CONTAINER_MEM_LIMIT=80g

# ============================================================
# 共有メモリサイズ
# ============================================================
# OpenMPI のプロセス間通信で使う。デフォルト(64MB)では不足するため
# 数GBに引き上げる。
CONTAINER_SHM_SIZE=4gb

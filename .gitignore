# DS_Store
.DS_Store

# .vscode
.vscode

# PDF files
*.pdf

# Claude files
.claude
.claude-notes
.claude-screenshots

# Environment variables
.env

# Simulation output (fallback directory when SIM_OUTPUT_DIR is not set to host SSD)
simulations/

# Phase 4 解析出力 (compare-stage-a 等の JSON / plot 出力先)
reports/

# feasibility / sweep ログ (host 側のメモリサンプラ + cactus stdout)
_logs/

# Python ランタイム生成物
__pycache__/
*.py[cod]
.pytest_cache/

# Einstein Toolkit 公式パラメータファイル（ライセンスは上流に従う、make fetch-* で取得）
par/GW150914/*.rpar
par/GW150914/*.par
par/GW150914/generated/
par/qc0-mclachlan/*.par
par/qc0-mclachlan/generated/

# Zenodo N=28 公開診断データ (10.5281/zenodo.155394, make fetch-zenodo-n28 で取得)
data/GW150914_N28_zenodo/*.tar.xz
data/GW150914_N28_zenodo/*.tar.bz2
data/GW150914_N28_zenodo/*.zip
data/GW150914_N28_zenodo/extracted/
